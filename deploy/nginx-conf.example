server {
    listen 80;
    # 替换为您的域名或是绑定公网IP，如 123.45.67.89
    server_name www.trendbot.cn trendbot.cn;

    # 这里处理 /nanning_agents_mvp/ 及其背后的 Node.js 动态端口
    location /nanning_agents_mvp/ {
        # 我们之前在设计上设置了后台的 NodeJS 在 8016 上，
        # 且我们在代码的前端跳转上做了适配
        proxy_pass http://127.0.0.1:8016/;

        # 需要告知后台是这个前缀发起的反代请求，将用户的实际IP穿透过去
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 为了兼容较大文件的上传（例如pdf，docx），放大限制，当前设置单次不超过 50M
        client_max_body_size 50m;
        
        # 减少超时情况
        proxy_connect_timeout 90;
        proxy_send_timeout 90;
        proxy_read_timeout 90;
    }

    # 为了更好的安全性：只允许通过 Nginx 访问我们的静态前端主服务
    # 防止黑客猜解端口强穿防火墙
}
